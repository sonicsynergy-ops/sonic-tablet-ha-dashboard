# /config/dashboards/hemma/hemma.yaml.example
# Hemma Dashboard - Example Configuration
# ============================================================================
# Copy or rename this file to hemma.yaml and customize the entity IDs to match
# your Home Assistant setup. Search for "YOUR_" to find all placeholders.
#
# REQUIRED: Replace all entity IDs with your own entities
# OPTIONAL: Adjust room names, add/remove rooms, customize features
# ============================================================================

button_card_templates: !include_dir_merge_named /config/dashboards/templates/button_cards

# Kiosk Mode (optional - requires kiosk-mode HACS integration)
# Uncomment and customize if you want to hide certain UI elements
# kiosk_mode:
#   hide_header: true
#   hide_sidebar: false
#   hide_dialog_light_settings_actions: true
#   hide_dialog_logbook: true
#   hide_dialog_attributes: false
#   mobile_settings:
#     hide_header: true
#     hide_sidebar: false
#   user_settings:
#     - users:
#         - "tablet"
#       hide_header: true
#       hide_sidebar: false
#       hide_dialog_logbook: true
#       hide_dialog_light_settings_actions: true
#       hide_dialog_header_breadcrumb_navigation: true
#       hide_dialog_header_history: true
#       hide_dialog_attributes: false

views:
  # ------------------------------------------------------
  # HOME
  # ------------------------------------------------------
  # The main overview room - typically shows whole-home controls
  # and media player status across all rooms
  # ------------------------------------------------------
  - type: custom:grid-layout
    title: home
    path: home
    layout: !include /config/dashboards/templates/includes/hemma_screen_layout.yaml
    cards:
      # ROOM HERO CARD
      - type: custom:button-card
        template: hemma_room
        name: Home
        variables:
          # Image Configuration
          # Demo images are included in www/hemma/rooms/ — replace with your own photos when ready.
          # Place your images at: /config/www/hemma/rooms/home.jpg (light mode)
          #                       /config/www/hemma/rooms/home-night.jpg (dark mode)
          image: home-demo
          # Define all room images here once and reuse them across rooms via the YAML anchor.
          # This preloads backgrounds so room transitions are instant.
          preload_rooms: &room_images
            - home-demo
            - livingroom-demo
            - kitchen-demo
            - bedroom-demo
          image_position: center center
          # mobile_background: true # Enable this if you add mobile backgrounds to /local/hemma/mobile/

          # Climate (shows group badge + expandable sub-badges for temp/humidity/quality)
          show_climate: false
          # climate_entity_1: climate.YOUR_THERMOSTAT
          # climate_entity_2: climate.YOUR_THERMOSTAT_2   # optional, up to 3

          # Sensors (used by the climate sub-badges when show_climate is true)
          # temp_sensor_1: sensor.YOUR_HOME_TEMPERATURE
          # temp_sensor_2: sensor.YOUR_TEMPERATURE_2      # optional additional temp sensors
          # temp_sensor_3: sensor.YOUR_TEMPERATURE_3
          # temp_sensor_4: sensor.YOUR_TEMPERATURE_4
          # temp_sensor_5: sensor.YOUR_TEMPERATURE_5
          # humidity_sensor: sensor.YOUR_HUMIDITY
          # quality_sensor: sensor.YOUR_AIR_QUALITY

          # Air Quality Popup (optional - shown when tapping the air quality badge)
          # Requires show_climate: true and quality_sensor above
          # aqi_room_name: Home
          # aqi_entity_pm25: sensor.YOUR_PM25
          # aqi_entity_pm10: sensor.YOUR_PM10
          # aqi_entity_voc: sensor.YOUR_VOC
          # aqi_entity_co2: sensor.YOUR_CO2
          # aqi_entity_temp: sensor.YOUR_AQI_TEMP
          # aqi_entity_humidity: sensor.YOUR_AQI_HUMIDITY

          # Lights Badge (optional - shows a light group badge)
          show_lights: false
          light_group_entity: light.YOUR_HOME_LIGHT_GROUP
          # light_entity_1: light.YOUR_ROOM_LIGHT_GROUP_1
          # light_entity_2: light.YOUR_ROOM_LIGHT_GROUP_2
          # light_entity_3: light.YOUR_ROOM_LIGHT_GROUP_3
          # light_entity_4: light.YOUR_ROOM_LIGHT_GROUP_4

          # Weather Widget
          show_weather: true
          weather_entity: weather.YOUR_WEATHER            # e.g., weather.home, weather.pirateweather
          weather_temp_sensor: sensor.YOUR_OUTDOOR_TEMP   # e.g., sensor.outdoor_temperature

          # Temperature Unit (affects comfort labels like "Cool", "Warm", etc.)
          temp_unit: 'F'                                  # 'F' for Fahrenheit, 'C' for Celsius

          # Presence Badges (optional - requires person/status sensors)
          # Shows a group badge on the hero card; tap to expand individual badges
          show_presence: false
          # presence_entity_1: sensor.YOUR_PERSON_1_STATUS  # optional, up to 4
          # presence_entity_2: sensor.YOUR_PERSON_2_STATUS
          # presence_entity_3: sensor.YOUR_PERSON_3_STATUS
          # presence_entity_4: sensor.YOUR_PERSON_4_STATUS

          # Media Player Badges (shows what's playing across rooms)
          show_media: true
          show_media_player_1: true
          media_player_1: media_player.YOUR_ENTITY        # e.g., media_player.spotify
          show_media_player_2: true
          media_player_2: media_player.YOUR_ENTITY        # e.g., media_player.living_room_apple_tv
          show_media_player_3: true
          media_player_3: media_player.YOUR_ENTITY        # e.g., media_player.bedroom_apple_tv
          show_media_player_4: true
          media_player_4: media_player.YOUR_ENTITY        # e.g., media_player.kitchen
          # show_media_player_5: true
          # media_player_5: media_player.YOUR_ENTITY      # optional fifth player

      # MOBILE NAVBAR
      - !include /config/dashboards/templates/includes/hemma_navbar_mobile.yaml

      # ENTITY CARDS
      - type: custom:layout-card
        class: hemma-entities
        layout_type: custom:grid-layout
        layout: !include /config/dashboards/templates/includes/hemma_entity_layout.yaml
        cards:
          # Thermostat
          - type: custom:button-card
            template: hemma_thermostat
            entity: climate.YOUR_HOME_THERMOSTAT          # e.g., climate.home
            name: Thermostat
            variables:
              position: 1
              temp_sensor: sensor.YOUR_HOME_TEMPERATURE

          # Front Door Lock
          - type: custom:button-card
            template: hemma_lock
            entity: lock.YOUR_FRONT_DOOR                  # e.g., lock.front_door
            name: Front Door
            variables:
              position: 2
              icon: door
              show_toggle: true
              battery_entity: sensor.YOUR_LOCK_BATTERY    # optional

          # Doorbell Camera
          - type: custom:button-card
            template: hemma_doorbell
            entity: camera.YOUR_DOORBELL                  # e.g., camera.front_door
            name: Doorbell
            variables:
              position: 3
              icon: doorbell
              battery_entity: sensor.YOUR_DOORBELL_BATTERY  # optional

          # Battery Status (shows battery levels for multiple devices in a popup)
          - type: custom:button-card
            template: hemma_battery
            name: Battery Status
            entity: sensor.YOUR_PRIMARY_BATTERY           # any battery entity to display on the card
            variables:
              position: 4
              entity_filter:
                - sensor.YOUR_LOCK_BATTERY
                - sensor.YOUR_DOORBELL_BATTERY
                - sensor.YOUR_MOTION_SENSOR_BATTERY
                # Add any additional battery sensors here

          # Network Speed (shows WAN download/upload, ping, and sub-interface stats)
          - type: custom:button-card
            entity: sensor.YOUR_WAN_DOWNLOAD_SPEED        # e.g., sensor.router_wan_download_speed
            template: hemma_network
            name: Network
            variables:
              position: 5
              room_name: Home
              entity_upload: sensor.YOUR_WAN_UPLOAD_SPEED
              entity_status: binary_sensor.YOUR_INTERNET_STATUS  # e.g., binary_sensor.router_internet
              entity_ping: sensor.YOUR_PING                      # e.g., sensor.ping_cloudflare_rtt
              entity_stat_1: sensor.YOUR_WIRED_DOWNLOAD_SPEED    # optional sub-stats
              entity_stat_2: sensor.YOUR_WIRED_UPLOAD_SPEED
              entity_stat_3: sensor.YOUR_WIFI_DOWNLOAD_SPEED
              entity_stat_4: sensor.YOUR_WIFI_UPLOAD_SPEED

          # Energy Usage (whole-home power consumption with today/month totals)
          - type: custom:button-card
            entity: sensor.YOUR_HOME_POWER                # e.g., sensor.home_current_consumption
            template: hemma_energy
            name: Energy Usage
            variables:
              position: 6
              room_name: Home
              entity_power: sensor.YOUR_HOME_POWER
              entity_usage_today: sensor.YOUR_ENERGY_TODAY          # optional kWh today
              entity_usage_month: sensor.YOUR_ENERGY_MONTH          # optional kWh this month
              entity_cost_today: sensor.YOUR_ENERGY_COST_TODAY      # optional cost today
              entity_cost_month: sensor.YOUR_ENERGY_COST_MONTH      # optional cost this month

          # Updates (shows pending Home Assistant / integration updates)
          - type: custom:button-card
            template: hemma_updates
            entity: sensor.YOUR_UPDATES                   # e.g., sensor.pending_updates
            name: Available Updates
            variables:
              position: 7

          # Plex Recently Added (optional)
          # Requires the plex_recently_added HACS integration and hemma_helpers.yaml sensor.
          # Shows count of items added in last 7 days; goes active when count > 0.
          # - type: custom:button-card
          #   template: hemma_plex_recently_added
          #   entity: sensor.plex_recently_added_count
          #   name: Plex
          #   variables:
          #     position: 8

          # Motion Overview Card (optional)
          # Shows active room name when motion is detected, "Clear" when none.
          # - type: custom:button-card
          #   template: hemma_motion
          #   variables:
          #     position: 9
          #     default_name: Home
          #     sensor_1: binary_sensor.YOUR_LIVING_ROOM_MOTION
          #     label_1: Living Room
          #     sensor_2: binary_sensor.YOUR_BEDROOM_MOTION
          #     label_2: Bedroom
          #     sensor_3: binary_sensor.YOUR_KITCHEN_MOTION
          #     label_3: Kitchen

  # ------------------------------------------------------
  # LIVING ROOM
  # ------------------------------------------------------
  - type: custom:grid-layout
    title: living-room
    path: living-room
    layout: !include /config/dashboards/templates/includes/hemma_screen_layout.yaml
    cards:
      # ROOM HERO CARD
      - type: custom:button-card
        template: hemma_room
        name: Living Room
        variables:
          image: livingroom-demo
          preload_rooms: *room_images
          image_position: center center
          # mobile_background: true

          # Climate (optional)
          show_climate: false
          # climate_entity_1: climate.YOUR_LIVING_ROOM_CLIMATE

          # Sensors
          # temp_sensor_1: sensor.YOUR_LIVING_ROOM_TEMP
          # temp_sensor_2: sensor.YOUR_TEMP_2
          # humidity_sensor: sensor.YOUR_LIVING_ROOM_HUMIDITY
          # quality_sensor: sensor.YOUR_AIR_QUALITY

          # Air Quality Popup (optional)
          # aqi_room_name: Living Room
          # aqi_entity_pm25: sensor.YOUR_PM25
          # aqi_entity_pm10: sensor.YOUR_PM10
          # aqi_entity_voc: sensor.YOUR_VOC
          # aqi_entity_co2: sensor.YOUR_CO2
          # aqi_entity_temp: sensor.YOUR_AQI_TEMP
          # aqi_entity_humidity: sensor.YOUR_AQI_HUMIDITY

          # Light Badge (optional)
          show_lights: false
          # light_entity_1: light.YOUR_LIVING_ROOM_LIGHTS

          # Weather Widget (optional)
          show_weather: false
          # weather_entity: weather.YOUR_WEATHER
          # weather_temp_sensor: sensor.YOUR_OUTDOOR_TEMP
          temp_unit: 'F'

          # Media Player Badges (optional)
          show_media: false
          # show_media_player_1: true
          # media_player_1: media_player.YOUR_LIVING_ROOM_PLAYER

      # MOBILE NAVBAR
      - !include /config/dashboards/templates/includes/hemma_navbar_mobile.yaml

      # ENTITY CARDS
      - type: custom:layout-card
        class: hemma-entities
        layout_type: custom:grid-layout
        layout: !include /config/dashboards/templates/includes/hemma_entity_layout.yaml
        cards:
          - type: custom:button-card
            template: hemma_thermostat
            entity: climate.YOUR_LIVING_ROOM_CLIMATE
            name: Thermostat
            variables:
              position: 1
              temp_sensor: sensor.YOUR_LIVING_ROOM_TEMP

          - type: custom:button-card
            template: hemma_light
            entity: light.YOUR_LIVING_ROOM_LIGHTS
            name: Lights
            variables:
              position: 2
              icon: light
              show_toggle: true

          - type: custom:button-card
            template: hemma_media
            entity: media_player.YOUR_LIVING_ROOM_APPLE_TV
            name: Apple TV
            variables:
              position: 3
              icon: apple_tv
              show_progress: true
              progress_entity: media_player.YOUR_LIVING_ROOM_APPLE_TV

          - type: custom:button-card
            template: hemma_media
            entity: media_player.YOUR_LIVING_ROOM_TV
            name: TV
            variables:
              position: 4
              icon: tv
              show_toggle: true

          - type: custom:button-card
            template: hemma_media
            entity: media_player.YOUR_LIVING_ROOM_SPEAKER
            name: Sonos
            variables:
              position: 5
              icon: speaker

          # Active Energy (room-level power monitoring)
          - type: custom:button-card
            entity: sensor.YOUR_LIVING_ROOM_POWER
            template: hemma_energy
            name: Active Energy
            variables:
              position: 6
              room_name: Living Room
              entity_power: sensor.YOUR_LIVING_ROOM_POWER
              entity_usage_today: sensor.YOUR_LIVING_ROOM_ENERGY_TODAY    # optional
              entity_usage_month: sensor.YOUR_LIVING_ROOM_ENERGY_MONTH    # optional
              entity_cost_today: sensor.YOUR_LIVING_ROOM_COST_TODAY       # optional
              entity_cost_month: sensor.YOUR_LIVING_ROOM_COST_MONTH       # optional

          - type: custom:button-card
            template: hemma_curtain
            entity: cover.YOUR_LIVING_ROOM_CURTAIN
            name: Curtain
            variables:
              position: 7
              icon: curtain
              show_toggle: true

          - type: custom:button-card
            template: hemma_fan
            entity: fan.YOUR_LIVING_ROOM_FAN
            name: Fan
            variables:
              position: 8
              icon: fan
              show_toggle: true

          # Plant Monitor (optional - requires plant integration + sensors)
          - type: custom:button-card
            template: hemma_plant
            entity: plant.YOUR_PLANT                      # e.g., plant.rubber_tree
            name: Rubber Tree
            variables:
              position: 9
              sensors:
                - sensor.YOUR_PLANT_MOISTURE
                - sensor.YOUR_PLANT_ILLUMINANCE
                - sensor.YOUR_PLANT_TEMPERATURE
                - sensor.YOUR_PLANT_AIR_HUMIDITY
                - sensor.YOUR_PLANT_CONDUCTIVITY

  # ------------------------------------------------------
  # KITCHEN
  # ------------------------------------------------------
  - type: custom:grid-layout
    title: kitchen
    path: kitchen
    layout: !include /config/dashboards/templates/includes/hemma_screen_layout.yaml
    cards:
      # ROOM HERO CARD
      - type: custom:button-card
        template: hemma_room
        name: Kitchen
        variables:
          image: kitchen-demo
          preload_rooms: *room_images
          image_position: center center
          # mobile_background: true

          # Climate (optional)
          show_climate: false
          # climate_entity_1: climate.YOUR_KITCHEN_CLIMATE

          # Sensors
          # temp_sensor_1: sensor.YOUR_KITCHEN_TEMP
          # humidity_sensor: sensor.YOUR_KITCHEN_HUMIDITY
          # quality_sensor: sensor.YOUR_AIR_QUALITY

          # Air Quality Popup (optional)
          # aqi_room_name: Kitchen
          # aqi_entity_pm25: sensor.YOUR_PM25
          # aqi_entity_pm10: sensor.YOUR_PM10
          # aqi_entity_voc: sensor.YOUR_VOC
          # aqi_entity_co2: sensor.YOUR_CO2
          # aqi_entity_temp: sensor.YOUR_AQI_TEMP
          # aqi_entity_humidity: sensor.YOUR_AQI_HUMIDITY

          show_weather: false
          # weather_entity: weather.YOUR_WEATHER
          # weather_temp_sensor: sensor.YOUR_OUTDOOR_TEMP
          temp_unit: 'F'

          # Light Badge (optional)
          show_lights: false
          # light_entity_1: light.YOUR_KITCHEN_LIGHTS

          # Media Player Badges (optional)
          show_media: false
          # show_media_player_1: true
          # media_player_1: media_player.YOUR_KITCHEN_PLAYER

      # MOBILE NAVBAR
      - !include /config/dashboards/templates/includes/hemma_navbar_mobile.yaml

      # ENTITY CARDS
      - type: custom:layout-card
        class: hemma-entities
        layout_type: custom:grid-layout
        layout: !include /config/dashboards/templates/includes/hemma_entity_layout.yaml
        cards:
          - type: custom:button-card
            template: hemma_vacuum
            entity: vacuum.YOUR_VACUUM
            name: Robot Vacuum
            variables:
              position: 1
              icon: vacuum

          - type: custom:button-card
            template: hemma_light
            entity: light.YOUR_KITCHEN_LIGHTS
            name: Lights
            variables:
              position: 2
              icon: light
              show_toggle: true

          - type: custom:button-card
            template: hemma_media
            entity: media_player.YOUR_KITCHEN_SPEAKER
            name: Speaker
            variables:
              position: 3
              icon: speaker
              show_progress: true

          - type: custom:button-card
            template: hemma_media
            entity: media_player.YOUR_KITCHEN_HOMEPOD     # optional second speaker
            name: HomePod
            variables:
              position: 4
              icon: homepod
              show_progress: true

  # ------------------------------------------------------
  # BEDROOM
  # ------------------------------------------------------
  - type: custom:grid-layout
    title: bedroom
    path: bedroom
    layout: !include /config/dashboards/templates/includes/hemma_screen_layout.yaml
    cards:
      # ROOM HERO CARD
      - type: custom:button-card
        template: hemma_room
        name: Bedroom
        variables:
          image: bedroom-demo
          preload_rooms: *room_images
          image_position: center center
          # mobile_background: true

          # Climate (optional)
          show_climate: false
          # climate_entity_1: climate.YOUR_BEDROOM_CLIMATE

          # Sensors
          # temp_sensor_1: sensor.YOUR_BEDROOM_TEMP
          # humidity_sensor: sensor.YOUR_BEDROOM_HUMIDITY
          # quality_sensor: sensor.YOUR_BEDROOM_AIR_QUALITY

          # Air Quality Popup (optional)
          # aqi_room_name: Bedroom
          # aqi_entity_pm25: sensor.YOUR_PM25
          # aqi_entity_pm10: sensor.YOUR_PM10
          # aqi_entity_voc: sensor.YOUR_VOC
          # aqi_entity_co2: sensor.YOUR_CO2
          # aqi_entity_temp: sensor.YOUR_AQI_TEMP
          # aqi_entity_humidity: sensor.YOUR_AQI_HUMIDITY

          show_weather: false
          # weather_entity: weather.YOUR_WEATHER
          # weather_temp_sensor: sensor.YOUR_OUTDOOR_TEMP
          temp_unit: 'F'

          # Light Badge (optional)
          show_lights: false
          # light_entity_1: light.YOUR_BEDROOM_LIGHTS

          # Media Player Badges (optional)
          show_media: false
          # show_media_player_1: true
          # media_player_1: media_player.YOUR_BEDROOM_PLAYER

      # MOBILE NAVBAR
      - !include /config/dashboards/templates/includes/hemma_navbar_mobile.yaml

      # ENTITY CARDS
      - type: custom:layout-card
        class: hemma-entities
        layout_type: custom:grid-layout
        layout: !include /config/dashboards/templates/includes/hemma_entity_layout.yaml
        cards:
          - type: custom:button-card
            template: hemma_thermostat
            entity: climate.YOUR_BEDROOM_CLIMATE
            name: Thermostat
            variables:
              position: 1
              temp_sensor: sensor.YOUR_BEDROOM_TEMP

          - type: custom:button-card
            template: hemma_light
            entity: light.YOUR_BEDROOM_LIGHTS
            name: Lights
            variables:
              position: 2
              icon: light
              show_toggle: true

          - type: custom:button-card
            template: hemma_media
            entity: media_player.YOUR_BEDROOM_APPLE_TV
            name: Apple TV
            variables:
              position: 3
              icon: apple_tv
              show_progress: true
              progress_entity: media_player.YOUR_BEDROOM_APPLE_TV

          - type: custom:button-card
            template: hemma_media
            entity: media_player.YOUR_BEDROOM_TV
            name: TV
            variables:
              position: 4
              icon: tv
              show_toggle: true

          - type: custom:button-card
            template: hemma_media
            entity: media_player.YOUR_BEDROOM_SPEAKER
            name: Speaker
            variables:
              position: 5
              icon: speaker

          # Active Energy (room-level power monitoring)
          - type: custom:button-card
            entity: sensor.YOUR_BEDROOM_POWER
            template: hemma_energy
            name: Active Energy
            variables:
              position: 6
              room_name: Bedroom
              entity_power: sensor.YOUR_BEDROOM_POWER
              entity_usage_today: sensor.YOUR_BEDROOM_ENERGY_TODAY    # optional
              entity_usage_month: sensor.YOUR_BEDROOM_ENERGY_MONTH    # optional
              entity_cost_today: sensor.YOUR_BEDROOM_COST_TODAY       # optional
              entity_cost_month: sensor.YOUR_BEDROOM_COST_MONTH       # optional

          - type: custom:button-card
            template: hemma_fan
            entity: fan.YOUR_BEDROOM_FAN
            name: Fan
            variables:
              position: 7
              icon: fan
              show_toggle: true

          - type: custom:button-card
            template: hemma_curtain
            entity: cover.YOUR_BEDROOM_CURTAIN
            name: Curtain
            variables:
              position: 8
              icon: curtain

          - type: custom:button-card
            template: hemma_air_purifier
            entity: fan.YOUR_AIR_PURIFIER
            name: Air Purifier
            variables:
              position: 9
              icon: purifier
              show_toggle: true

          - type: custom:button-card
            template: hemma_humidifier
            entity: humidifier.YOUR_HUMIDIFIER
            name: Humidifier
            variables:
              position: 10
              icon: humidifier
              show_toggle: true

          # Plant Monitor (optional - requires plant integration + sensors)
          - type: custom:button-card
            template: hemma_plant
            entity: plant.YOUR_PLANT                      # e.g., plant.monstera
            name: Monstera
            variables:
              position: 11
              sensors:
                - sensor.YOUR_PLANT_MOISTURE
                - sensor.YOUR_PLANT_ILLUMINANCE
                - sensor.YOUR_PLANT_TEMPERATURE
                - sensor.YOUR_PLANT_AIR_HUMIDITY
                - sensor.YOUR_PLANT_CONDUCTIVITY
